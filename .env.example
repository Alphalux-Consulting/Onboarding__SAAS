# Firebase Configuration for Development
# Get these values from Firebase Console > Project Settings > Your apps > Web app
# IMPORTANT: Never commit your actual keys to git. Use .env.local for real keys

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_id

# Application Settings
VITE_APP_NAME=Alphalux Onboarding
VITE_APP_URL=http://localhost:5173

# CEO Welcome Video
# Add your YouTube video ID or full URL here
# Example: https://www.youtube.com/embed/VIDEO_ID or just VIDEO_ID
VITE_CEO_VIDEO_URL=https://youtu.be/your_video_id

# Tutorial Videos for Each Module
# Meta/Facebook Ads setup tutorial
VITE_META_VIDEO_URL=

# Google Ads and Maps setup tutorial
VITE_GOOGLE_VIDEO_URL=

# Slack setup tutorial
VITE_SLACK_VIDEO_URL=

# IA/WhatsApp Bot setup tutorial
VITE_IA_VIDEO_URL=

# Additional tutorial videos as needed
VITE_BRAND_VIDEO_URL=
VITE_CLIENT_IDEAL_VIDEO_URL=
